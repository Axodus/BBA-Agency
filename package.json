{
  "name": "bba-agency",
  "version": "1.0.0",
  "description": "AxodusBBA - Unificação dos projetos Axodus e BBA Agency",
  "main": "dist/pipelines/campaign.flow.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/pipelines/campaign.flow.ts",
    "dev:axodus": "ts-node --transpile-only src/pipelines/campaign.flow.ts",
    "mcp": "ts-node --transpile-only src/tools/mcp-server.ts",
    "memory:init": "ts-node --transpile-only src/memory/init.ts",
    "memory:health": "ts-node --transpile-only src/utils/test-memory-namespaces.ts",
    "memory:up": "docker compose -f docker-compose.memory.yml up -d",
    "memory:down": "docker compose -f docker-compose.memory.yml down",
    "tests": "npm run test:agent && npm run test:brief && npm run test:audience && npm run test:trend && npm run test:brand && npm run test:planner && npm run test:design && npm run test:motion && npm run test:ux && npm run test:ads && npm run test:growth && npm run test:contracts && npm run test:permissions && npm run test:ideation && npm run test:memory && npm run test:hitl && npm run test:cost", 
    "test:agent": "ts-node --transpile-only src/utils/test-agent.ts",
    "test:brief": "ts-node --transpile-only src/utils/test-brief-interpreter.ts",
    "test:audience": "ts-node --transpile-only src/utils/test-audience-profiler.ts",
    "test:trend": "ts-node --transpile-only src/utils/test-trend-analyst.ts",
    "test:brand": "ts-node --transpile-only src/utils/test-brand-strategist.ts",
    "test:planner": "ts-node --transpile-only src/utils/test-campaign-planner.ts",
    "test:design": "ts-node --transpile-only src/utils/test-visual-designer.ts",
    "test:motion": "ts-node --transpile-only src/utils/test-motion-designer.ts",
    "test:ux": "ts-node --transpile-only src/utils/test-ux-creative.ts",
    "test:ads": "ts-node --transpile-only src/utils/test-ads-specialist.ts",
    "test:growth": "ts-node --transpile-only src/utils/test-growth-hacker.ts",
    "test:contracts": "ts-node --transpile-only src/utils/test-contract-violation.ts",
    "test:permissions": "ts-node --transpile-only src/utils/test-permission-denied.ts",
    "test:ideation": "ts-node --transpile-only src/utils/test-parallel-ideation.ts",
    "test:memory": "ts-node --transpile-only src/utils/test-memory-namespaces.ts",
    "test:hitl": "ts-node --transpile-only src/utils/test-hitl-flow.ts",
    "test:cost": "ts-node --transpile-only src/utils/test-cost-overflow.ts",
    "test:creative": "ts-node --transpile-only src/utils/test-creative-director.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axodus/BBA-Agency.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Axodus/BBA-Agency/issues"
  },
  "homepage": "https://github.com/Axodus/BBA-Agency#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@chroma-core/default-embed": "^0.1.9",
    "@types/node": "^25.6.0",
    "chromadb": "^3.4.3",
    "dotenv": "^17.4.2",
    "mongodb": "^7.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  }
}
